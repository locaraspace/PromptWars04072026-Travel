// TravelAI — Prisma schema
//
// Prisma 7 notes:
//  - The datasource connection URL comes from prisma.config.ts (env DATABASE_URL).
//  - The client is emitted to src/generated/prisma (gitignored, regenerated).
//  - Models are PascalCase; @@map/@map keep DB tables/columns in snake_case to
//    match the agreed schema names.
//
// Design:
//  - String cuid() IDs everywhere (Better Auth compatible; auth satellite models
//    Session/Account/Verification are added in Step 3 via the Better Auth CLI).
//  - A Destination owns its content children; deleting a Destination cascades.
//  - Heritage is one-to-one per Destination. Events are cached with fetch/expiry.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Origin of a piece of content: hand-curated seed vs generated by AI.
enum ContentSource {
  SEED
  AI_GENERATED
}

// ---------------------------------------------------------------------------
// Auth / users
// ---------------------------------------------------------------------------

/// Application user. Shaped to be Better Auth-compatible (id, name, email,
/// emailVerified, image, timestamps). Credentials (hashed password) live on the
/// Account model added in Step 3.
model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false) @map("email_verified")
  image         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  searchHistory SearchHistory[]
  savedPlaces   SavedPlace[]
  sessions      Session[]
  accounts      Account[]

  @@map("users")
}

// ---------------------------------------------------------------------------
// Better Auth satellite models (managed by Better Auth via the Prisma adapter).
// Field names are camelCase because Better Auth addresses them by Prisma field
// name; DB columns are @map-ped to snake_case for consistency.
// ---------------------------------------------------------------------------

/// An authenticated session (Better Auth).
model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime @map("expires_at")
  token     String   @unique
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

/// A credential/OAuth account for a user (Better Auth). The hashed password for
/// email/password auth is stored here in `password`.
model Account {
  id                    String    @id @default(cuid())
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("accounts")
}

/// Verification tokens (email verification, password reset) — Better Auth.
model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([identifier])
  @@map("verifications")
}

// ---------------------------------------------------------------------------
// Destinations + owned content
// ---------------------------------------------------------------------------

/// A travel destination. `slug` is the normalized lookup key used by the search
/// cache. Rich, journalist-quality prose lives in `description`.
model Destination {
  id           String        @id @default(cuid())
  slug         String        @unique
  name         String
  city         String?
  region       String?
  country      String
  summary      String? // short one-liner for cards
  description  String // rich, immersive intro
  bestSeason   String?       @map("best_season")
  heroImageUrl String?       @map("hero_image_url")
  source       ContentSource @default(SEED)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  attractions         Attraction[]
  hiddenGems          HiddenGem[]
  heritageStory       HeritageStory?
  culturalExperiences CulturalExperience[]
  localFood           LocalFood[]
  travelTips          TravelTip[]
  localEvents         LocalEvent[]
  searchHistory       SearchHistory[]
  savedPlaces         SavedPlace[]

  @@index([country])
  @@map("destinations")
}

/// A notable attraction within a destination.
model Attraction {
  id            String   @id @default(cuid())
  destinationId String   @map("destination_id")
  title         String
  description   String
  category      String?
  area          String?
  bestTime      String?  @map("best_time")
  entryInfo     String?  @map("entry_info")
  imageUrl      String?  @map("image_url")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  destination Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@index([destinationId])
  @@map("attractions")
}

/// An off-the-beaten-path spot. Carries the full "hidden gem" narrative fields.
model HiddenGem {
  id               String   @id @default(cuid())
  destinationId    String   @map("destination_id")
  title            String
  description      String
  whyLocalsLove    String   @map("why_locals_love")
  whyTouristsMiss  String   @map("why_tourists_miss")
  bestVisitingTime String   @map("best_visiting_time")
  photographyTips  String   @map("photography_tips")
  nearbyFood       String   @map("nearby_food")
  imageUrl         String?  @map("image_url")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  destination Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@index([destinationId])
  @@map("hidden_gems")
}

/// Immersive heritage storytelling — one per destination.
model HeritageStory {
  id            String   @id @default(cuid())
  destinationId String   @unique @map("destination_id")
  title         String
  story         String // long-form immersive narrative
  era           String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  destination Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@map("heritage_story")
}

/// Cultural experiences — the product USP. Highest-detail content model.
model CulturalExperience {
  id                 String   @id @default(cuid())
  destinationId      String   @map("destination_id")
  title              String
  description        String
  duration           String
  estimatedCost      String   @map("estimated_cost")
  idealTime          String   @map("ideal_time")
  localTips          String   @map("local_tips")
  familyFriendly     Boolean  @default(true) @map("family_friendly")
  bookingRequired    Boolean  @default(false) @map("booking_required")
  authenticityRating Int      @map("authenticity_rating") // 1-5
  imageUrl           String?  @map("image_url")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  destination Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@index([destinationId])
  @@map("cultural_experiences")
}

/// Local cuisine recommendation.
model LocalFood {
  id            String   @id @default(cuid())
  destinationId String   @map("destination_id")
  name          String
  description   String
  whereToTry    String?  @map("where_to_try")
  type          String? // e.g. street food, vegetarian, dessert
  priceRange    String?  @map("price_range")
  mustTry       Boolean  @default(false) @map("must_try")
  imageUrl      String?  @map("image_url")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  destination Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@index([destinationId])
  @@map("local_food")
}

/// A practical travel tip (safety, transport, etiquette, money, etc.).
model TravelTip {
  id            String   @id @default(cuid())
  destinationId String   @map("destination_id")
  category      String?
  tip           String
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  destination Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@index([destinationId])
  @@map("travel_tips")
}

/// Festival/event near a destination. NOT permanent — refreshed via web search
/// and cached; `fetchedAt`/`expiresAt` drive re-fetching.
model LocalEvent {
  id            String    @id @default(cuid())
  destinationId String    @map("destination_id")
  title         String
  description   String
  venue         String?
  startDate     DateTime? @map("start_date")
  endDate       DateTime? @map("end_date")
  sourceUrl     String?   @map("source_url")
  fetchedAt     DateTime  @default(now()) @map("fetched_at")
  expiresAt     DateTime? @map("expires_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  destination Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@index([destinationId])
  @@map("local_events")
}

// ---------------------------------------------------------------------------
// User activity
// ---------------------------------------------------------------------------

/// A user's destination search. `normalizedQuery` mirrors the cache key; the
/// resolved destination is linked when one is found/created.
model SearchHistory {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  query           String
  normalizedQuery String   @map("normalized_query")
  destinationId   String?  @map("destination_id")
  createdAt       DateTime @default(now()) @map("created_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  destination Destination? @relation(fields: [destinationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([normalizedQuery])
  @@map("search_history")
}

/// A destination bookmarked by a user.
model SavedPlace {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  destinationId String   @map("destination_id")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  destination Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@unique([userId, destinationId])
  @@index([userId])
  @@map("saved_places")
}
